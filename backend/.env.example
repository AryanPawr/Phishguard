PHISHGUARD_ENVIRONMENT=development
PHISHGUARD_DATABASE_URL=sqlite:///./phishguard.db
PHISHGUARD_JWT_SECRET=replace-with-a-long-random-secret
PHISHGUARD_ADMIN_USERNAME=admin
PHISHGUARD_ADMIN_PASSWORD=change-me
PHISHGUARD_CORS_ORIGINS=http://localhost:5173
PHISHGUARD_CORS_ORIGIN_REGEX=^(chrome-extension|moz-extension)://[A-Za-z0-9_-]+$
PHISHGUARD_RATE_LIMIT_PER_MINUTE=120
