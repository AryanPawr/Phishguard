{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.phishguard.local/analyze-request.schema.json",
  "title": "PhishGuard Analyze Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["sender_email", "subject", "body_text", "links", "source"],
  "properties": {
    "sender_email": { "type": "string", "maxLength": 320 },
    "display_name": { "type": "string", "maxLength": 256 },
    "subject": { "type": "string", "maxLength": 512 },
    "body_text": { "type": "string", "maxLength": 50000 },
    "html": { "type": ["string", "null"], "maxLength": 120000 },
    "domain": { "type": "string", "maxLength": 255 },
    "heuristic_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "client_reasons": {
      "type": "array",
      "maxItems": 25,
      "items": { "type": "string", "maxLength": 240 }
    },
    "source": { "enum": ["gmail", "outlook", "generic", "api"] },
    "links": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["href"],
        "properties": {
          "href": { "type": "string", "maxLength": 2048 },
          "anchor_text": { "type": "string", "maxLength": 512 }
        }
      }
    }
  }
}

